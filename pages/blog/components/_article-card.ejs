<a href="/blog/articles/<%= url %>" class="block group relative bg-[#FBFBFB] border border-border rounded-2xl overflow-hidden hover:shadow-2xl hover:border-primary transition-all flex flex-col h-[480px]">
    <div class="h-52 overflow-hidden relative">
        <img src="<%= typeof coverImage !== 'undefined' && coverImage ? (coverImage.startsWith('http') || coverImage.startsWith('/blog/') ? coverImage : '/blog/assets/' + coverImage) : 'https://picsum.photos/seed/' + title + '/600/400' %>" 
             alt="<%= title %>" 
             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
        <% if (typeof tags !== 'undefined' && tags && tags.length > 0) { %>
            <span class="absolute top-6 left-6 bg-black text-white text-xs font-semibold px-3 py-1.5 rounded-full shadow-lg"><%= tags[0] %></span>
        <% } %>
    </div>
    <div class="p-5 md:p-6 flex-1 flex flex-col">
        <h2 class="text-base md:text-lg font-bold text-gray-900 leading-tight mb-3 md:mb-4 group-hover:text-primary transition-colors line-clamp-2"><%= title %></h2>
        <p class="text-sm text-gray-600 font-medium line-clamp-3 leading-relaxed mb-6"><%= typeof description !== 'undefined' ? description : '' %></p>
        
        <div class="mt-auto pt-6 border-t border-border/50 flex items-center justify-between">
            <div class="flex flex-col">
                <% 
                    let formattedDate = date;
                    try {
                        let d = (typeof date === 'string') ? new Date(date) : date;
                        if (d instanceof Date && !isNaN(d)) {
                            formattedDate = d.toLocaleDateString('pt-BR');
                        }
                    } catch (e) {
                        formattedDate = date;
                    }
                %>
                <time class="text-sm font-medium text-gray-500"><%= formattedDate %></time>
                <span class="text-sm font-medium text-primary">Ler resumo</span>
            </div>
            <div class="w-8 h-8 rounded-full border border-black flex items-center justify-center group-hover:bg-black group-hover:text-white transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
        </div>
    </div>
</a>
