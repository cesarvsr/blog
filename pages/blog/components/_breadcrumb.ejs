<% if (typeof items !== 'undefined' && items.length > 0) { %>
<nav class="flex items-center gap-2 text-xs font-semibold text-gray-500 uppercase tracking-wide mb-6">
    <% items.forEach((item, index) => { %>
        <% if (item.url) { %>
            <a href="<%= item.url %>" class="hover:text-black transition-colors max-w-[100px] sm:max-w-[150px] md:max-w-[200px] truncate" title="<%= item.label %>"><%= item.label %></a>
        <% } else { %>
            <span class="text-black max-w-[150px] sm:max-w-[250px] md:max-w-[350px] truncate" title="<%= item.label %>"><%= item.label %></span>
        <% } %>
        
        <% if (index < items.length - 1) { %>
            <span class="shrink-0">/</span>
        <% } %>
    <% }) %>
</nav>
<% } %>
