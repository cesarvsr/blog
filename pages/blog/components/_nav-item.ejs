<% 
    const isFolder = item.type === 'folder';
    const isActive = typeof currentPath !== 'undefined' && currentPath === item.url;
    
    // Check if any child is active to auto-open folder
    function hasActiveChild(node) {
        if (!node.children) return false;
        return node.children.some(child => 
            (typeof currentPath !== 'undefined' && currentPath === child.url) || hasActiveChild(child)
        );
    }
    const isOpen = isFolder && hasActiveChild(item);
%>

<div class="space-y-0.5">
    <% if (isFolder) { %>
        <details class="group/folder" <%= isOpen ? 'open' : '' %>>
            <summary class="flex items-center gap-2 px-2 py-1.5 text-sm font-medium text-gray-600 hover:bg-gray-100 hover:text-black rounded-md transition-all cursor-pointer list-none group">
                <span class="flex-1 truncate" title="<%= item.title %>"><%= item.title %></span>
                <span class="text-[10px] text-gray-400 group-hover:text-gray-600 transition-transform duration-200 group-open/folder:rotate-90 shrink-0">▶</span>
            </summary>
            
            <div class="pl-3 mt-0.5 space-y-0.5 border-l border-gray-200 ml-2.5">
                <% item.children.forEach(child => { %>
                    <%- include("_nav-item", { item: child, currentPath: currentPath }) %>
                <% }) %>
            </div>
        </details>
    <% } else { %>
        <a href="<%= item.url %>" class="flex items-center px-2 py-1.5 text-sm font-medium rounded-md transition-all <%= isActive ? 'text-primary bg-blue-50/50' : 'text-gray-600 hover:bg-gray-100 hover:text-black' %>" title="<%= item.title %>">
            <span class="truncate"><%= item.title %></span>
        </a>
    <% } %>
</div>
