<% 
    const isFolder = item.type === 'folder';
    const isActive = typeof currentPath !== 'undefined' && currentPath === item.url;
    
    // Check if any child is active to auto-open folder
    function hasActiveChild(node) {
        if (!node.children) return false;
        return node.children.some(child => 
            (typeof currentPath !== 'undefined' && currentPath === child.url) || hasActiveChild(child)
        );
    }
    const isOpen = isFolder && hasActiveChild(item);
%>

<div class="space-y-0.5">
    <% if (isFolder) { %>
        <details class="group/folder" <%= isOpen ? 'open' : '' %>>
            <summary class="flex items-center gap-3 px-3 py-2 text-xs font-bold text-gray-500 hover:bg-white hover:text-primary rounded-xl transition-all cursor-pointer list-none group border border-transparent hover:border-gray-200 shadow-none hover:shadow-sm">
                <div class="w-8 h-8 rounded-lg bg-gray-50 text-gray-400 group-hover:text-primary flex items-center justify-center transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                    </svg>
                </div>
                <a href="<%= item.url %>" class="flex-1 hover:text-primary transition-colors"><%= item.title %></a>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 caret-icon text-gray-400 group-hover:text-black transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </summary>
            
            <div class="pl-4 mt-0.5 space-y-0.5 border-l border-gray-100 ml-4">
                <% item.children.forEach(child => { %>
                    <%- include("_nav-item", { item: child, currentPath: currentPath }) %>
                <% }) %>
            </div>
        </details>
    <% } else { %>
        <a href="<%= item.url %>" class="flex items-center gap-3 px-3 py-2 text-xs font-bold rounded-xl transition-all group border <%= isActive ? 'text-primary bg-blue-50/50 border-blue-100 shadow-sm' : 'text-gray-500 hover:bg-white hover:text-primary border-transparent hover:border-gray-200' %>">
            <div class="w-8 h-8 rounded-lg <%= isActive ? 'bg-white text-primary' : 'bg-gray-50 text-gray-400 group-hover:text-primary' %> flex items-center justify-center transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
            <%= item.title %>
        </a>
    <% } %>
</div>
