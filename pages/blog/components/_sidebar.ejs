<!-- Sidebar Overlay for mobile -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden lg:hidden"></div>

<aside id="sidebar" class="fixed inset-y-0 left-0 w-56 border-r border-border overflow-y-auto flex flex-col bg-[#FBFBFB] shrink-0 z-40 transform -translate-x-full transition-transform duration-300 lg:static lg:translate-x-0">
    <%
        // Include machine-generated navTree data if the plugin hasn't passed it directly
        if (typeof navTree === 'undefined' || !navTree || navTree.length === 0) {
            try { %>
                <%- include("_nav-data") %>
            <% } catch (e) { }
            
            // Re-check after include
            if (typeof navTree === 'undefined' && typeof locals.navTree !== 'undefined') {
                navTree = locals.navTree;
            }
        }
        
        // Final fallback
        if (typeof navTree === 'undefined') {
            navTree = [];
        }
    %>
    <!-- Header/Logo Area -->
    <div class="pt-6 pb-2 px-4">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Principal</h3>
        <nav class="space-y-0.5">
            <% const isHomeActive = typeof currentPath !== 'undefined' && (currentPath === '/blog' || currentPath === '/blog/index.html' || currentPath === '/blog/articles'); %>
            <a href="/blog/articles" class="flex items-center px-2 py-1.5 text-sm font-medium rounded-md transition-all <%= isHomeActive ? 'text-primary bg-blue-50/50' : 'text-gray-600 hover:bg-gray-100 hover:text-black' %>">
                Início
            </a>
        </nav>
    </div>

    <div class="pt-4 pb-4 px-4">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Categorias</h3>
        <nav class="space-y-px">
            <% if (typeof navTree !== 'undefined' && navTree && navTree.length > 0) { %>
                <% navTree.forEach(item => { %>
                    <%- include("_nav-item", { item: item, currentPath: typeof currentPath !== 'undefined' ? currentPath : '' }) %>
                <% }) %>
            <% } else { %>
                <p class="text-xs text-gray-400 italic px-2">Categorias em breve...</p>
            <% } %>
        </nav>
    </div>

    <div class="mt-auto p-4 border-t border-border/50">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Suporte</h3>
        <nav class="space-y-0.5">
            <% const isCalcActive = typeof currentPath !== 'undefined' && (currentPath === '/blog/calculadora' || currentPath.includes('calculadora')); %>
            <a href="/blog/calculadora" class="flex items-center px-2 py-1.5 text-sm font-medium rounded-md transition-all <%= isCalcActive ? 'text-primary bg-blue-50/50' : 'text-gray-600 hover:bg-gray-100 hover:text-black' %>">
                Calculadoras
            </a>
        </nav>
    </div>
</aside>
