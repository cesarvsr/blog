<%- include("../../pages/blog/components/_head", { title: (locals.title || '') + " - Mapa Mental" }) %>
<body class="flex flex-col h-screen overflow-hidden bg-white antialiased">
    <%- include("../../pages/blog/components/_header") %>

    <div class="flex flex-1 overflow-hidden">
        <%- include("../../pages/blog/components/_sidebar", { currentPath: locals.currentPath, navTree: locals.navTree, navMapas: locals.navMapas }) %>

        <!-- Main Content Area: Map Visualizer -->
        <main class="flex-1 flex flex-col overflow-hidden bg-white p-0">
            <%- include("../../pages/blog/components/_mapa-content", { rawContent: locals.rawContent, postName: locals.title, categoryTitle: "Mapa Mental" }) %>
        </main>
    </div>

    <%- include("../../pages/blog/components/_scripts") %>

    <style>
        ::-webkit-scrollbar {
            width: 5px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #D1D5DB;
            border-radius: 10px;
        }
    </style>
</body>
</html>
